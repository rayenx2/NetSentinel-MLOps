# NetGuard-ML — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================================
# MongoDB Configuration
# ============================================================
# For local Docker setup (default):
MONGO_DB_USERNAME=admin
MONGO_DB_PASSWORD=netsentinel_pass

# For MongoDB Atlas (cloud) — uncomment and fill in:
# MONGO_DB_USERNAME=your_atlas_username
# MONGO_DB_PASSWORD=your_atlas_password
# MONGO_DB_HOST=cluster0.l5ee6dv.mongodb.net

# ============================================================
# MLflow Tracking
# ============================================================
# Local MLflow server (default with docker-compose):
MLFLOW_TRACKING_URI=http://localhost:5000

# DagsHub remote tracking (optional):
# MLFLOW_TRACKING_URI=https://dagshub.com/your_username/your_repo.mlflow
# DAGSHUB_USER_TOKEN=your_dagshub_token

# ============================================================
# Application Settings
# ============================================================
APP_ENV=development
LOG_LEVEL=INFO

# ============================================================
# AWS (only needed for cloud artifact sync — optional)
# ============================================================
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=eu-west-1
# S3_BUCKET_NAME=your-netsentinel-bucket
